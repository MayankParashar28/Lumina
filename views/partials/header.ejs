<!-- ✅ Title: Set by each page via locals.title -->
<title><%= locals.title || 'Lumina - The Voice of the Bold' %></title>

<!-- ✅ Canonical URL: Prevents duplicate page indexing -->
<% const BASE_URL = process.env.BASE_URL || 'https://lluminaa.vercel.app'; %>
<% const canonicalPath = locals.canonicalPath || '/'; %>
<link rel="canonical" href="<%= BASE_URL + canonicalPath %>">

<!-- ✅ Primary Meta Tags -->
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="description" content="<%= locals.metaDescription || 'A minimalist sanctuary where builders share insights and shape the future of tech.' %>">
<meta name="robots" content="<%= locals.noIndex ? 'noindex, nofollow' : 'index, follow' %>">
<meta name="author" content="<%= locals.metaAuthor || 'Lumina' %>">

<!-- ✅ Open Graph / Facebook (Complete) -->
<meta property="og:type" content="<%= locals.ogType || 'website' %>">
<meta property="og:site_name" content="Lumina">
<meta property="og:url" content="<%= BASE_URL + canonicalPath %>">
<meta property="og:title" content="<%= locals.title || 'Lumina - The Voice of the Bold' %>">
<meta property="og:description" content="<%= locals.metaDescription || 'A minimalist sanctuary where builders share insights and shape the future of tech.' %>">
<meta property="og:image" content="<%= locals.ogImage ? locals.ogImage : BASE_URL + '/images/default-cover.png' %>">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:locale" content="en_US">

<!-- ✅ Twitter Card (Complete) -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:site" content="@lumina_blog">
<meta name="twitter:title" content="<%= locals.title || 'Lumina - The Voice of the Bold' %>">
<meta name="twitter:description" content="<%= locals.metaDescription || 'A minimalist sanctuary where builders share insights and shape the future of tech.' %>">
<meta name="twitter:image" content="<%= locals.ogImage ? locals.ogImage : BASE_URL + '/images/default-cover.png' %>">

<link rel="icon" href="/favicon.ico" type="image/x-icon">

<!-- Preconnect for Performance -->
<link rel="preconnect" href="https://cdnjs.cloudflare.com">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preconnect" href="https://cdn.jsdelivr.net">

<!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<!-- Bootstrap JavaScript Bundle (Deferred for performance) -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>

<!-- icon link -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

<!-- jQuery CDN (Deferred) -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js" defer></script>

<!-- Inter Font -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<!-- Global Styles -->
<link rel="stylesheet" href="/css/global.css?v=7">